{
  "name": "gist",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "lerna run dev --parallel",
    "build": "lerna run build",
    "start": "lerna run start --parallel",
    "check": "ultracite fix --unsafe && lerna run check",
    "check-types": "lerna run check-types",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "lerna": "^9.0.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "ultracite": "7.6.1"
  }
}
