{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/refs/heads/master/src/schemas/json/package.json",
  "name": "verso",
  "version": "0.0.10",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "autobump": "go run scripts/autobump.go",
    "build": "lerna run build",
    "check": "ultracite fix --unsafe && lerna run check",
    "check-types": "lerna run check-types",
    "check:ci": "ultracite check && lerna run check",
    "dev": "lerna run dev",
    "format": "ultracite fix --unsafe && lerna run format",
    "prepare": "lefthook install",
    "start": "lerna run start --parallel",
    "test": "lerna run test"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "lerna": "^9.0.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "ultracite": "7.6.1"
  },
  "engines": {
    "node": ">=24"
  }
}
