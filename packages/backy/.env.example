# GitHub Personal Access Token (required for GitHub stats endpoint)
# Create a token at: https://github.com/settings/tokens
# No special scopes required for public data
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# GitHub username to fetch stats for
GITHUB_USERNAME=YOUR_GITHUB_USERNAME

# Backend server port
PORT=7000

# PostgreSQL connection string
DATABASE_URL=postgres://verso:verso_secure_password@localhost:5432/verso?sslmode=disable

# Optional: Allowed web origins for CORS (comma-separated)
# Default: http://localhost:3000,http://localhost:5173,http://localhost:7000
# WEB_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:7000

# Optional: Trusted proxy IPs for Gin (comma-separated)
TRUSTED_PROXIES=

# JWT access token signing secret (REQUIRED for auth)
# Must be at least 32 random bytes. Generate with: openssl rand -base64 32
JWT_ACCESS_TOKEN_SECRET=change-me-to-a-random-secret

# JWT settings
JWT_AUDIENCE=verso
JWT_ISSUER=verso

# Token time-to-live values
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Cookie settings
# COOKIE_SECURE defaults to true for non-localhost domains
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Optional: Override cookie names (defaults shown)
# ACCESS_TOKEN_COOKIE_NAME=verso_access_token
# REFRESH_TOKEN_COOKIE_NAME=verso_refresh_token
